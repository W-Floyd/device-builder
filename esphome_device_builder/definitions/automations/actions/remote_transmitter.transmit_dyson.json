{"id":"remote_transmitter.transmit_dyson","name":"Remote Transmitter → Transmit Dyson","description":"This [action](https://esphome.io/automations/actions#config-action) sends a Dyson cool AM07 infrared protocol code to a remote transmitter.","docs_url":"https://esphome.io/automations/actions","domain":"remote_transmitter","config_entries":[{"key":"code","type":"integer","label":"Code","description":"The 16-bit code to trigger on, e.g. 0x1200=power, 0x1215=fan++, 0x122a=swing..., see dumper output for more info.","required":true,"range":[0,65535],"display_format":"hex","templatable":true,"help_link":"https://esphome.io/components/remote_transmitter#configuration-variables"},{"key":"index","type":"integer","label":"Index","description":"The 8-bit rolling index. Defaults to `0xFF`.","default_value":"255","range":[0,255],"display_format":"hex","templatable":true,"advanced":true,"help_link":"https://esphome.io/components/remote_transmitter#configuration-variables"},{"key":"repeat","type":"string","label":"Repeat","display_format":null,"advanced":true},{"key":"transmitter_id","type":"id","label":"Transmitter ID","advanced":true}],"is_control_flow":false,"has_else_branch":false,"accepts_action_list":[],"scalar_shorthand_key":null}
